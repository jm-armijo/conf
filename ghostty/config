theme = deep
copy-on-select = true
scrollback-limit = 40971520
mouse-scroll-multiplier = 0.1
keybind = ctrl+s>\=new_split:right
keybind = ctrl+s>-=new_split:down
keybind = ctrl+s>right=goto_split:right
keybind = ctrl+s>left=goto_split:left
keybind = ctrl+s>down=goto_split:bottom
keybind = ctrl+s>up=goto_split:top
keybind = ctrl+s>page_up=goto_split:previous
keybind = ctrl+s>page_down=goto_split:next
keybind = ctrl+s>z=toggle_split_zoom
keybind = ctrl+s>r=reload_config
keybind = global:cmd+home=toggle_quick_terminal

split-divider-color = #0000ff
unfocused-split-opacity = 0.7
unfocused-split-fill = #000000
